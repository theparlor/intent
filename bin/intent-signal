#!/bin/bash
#
# intent-signal — Capture and manage signals
#
# Usage:
#   intent-signal "OTel traces show 40% of contracts fail on first pass"
#   intent-signal "Title here" --body "Longer description" --confidence 0.8
#   intent-signal "Title here" --source pr-review --author brien --trust 0.6
#   intent-signal review                    # Interactive triage of captured signals
#   intent-signal review SIG-003            # Review a specific signal
#   intent-signal dismiss SIG-003 --reason "Duplicate of SIG-001"
#   intent-signal cluster SIG-003,SIG-005 --name "Bootstrap tooling"
#   intent-signal promote SIG-003           # Promote signal to intent
#   intent-signal list                      # List all signals (default: active)
#   intent-signal list --status captured    # Filter by status
#   intent-signal show SIG-003              # Show full signal details
#
# Writes to .intent/signals/ in the nearest Intent-native repo.

set -euo pipefail

# --- Find .intent/ directory ---
find_intent_root() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -d "$dir/.intent" ]]; then
      echo "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

REPO_ROOT=$(find_intent_root) || {
  echo "Error: No .intent/ directory found. Are you in an Intent repo?"
  exit 1
}

SIGNALS_DIR="$REPO_ROOT/.intent/signals"

# --- Ensure signals directory exists ---
mkdir -p "$SIGNALS_DIR"

# --- Subcommand: capture ---
capture_signal() {
  local title="$1"
  shift
  local body=""
  local confidence="0.5"
  local source="cli"
  local author=""
  local trust=""

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --body)
        body="$2"
        shift 2
        ;;
      --confidence)
        confidence="$2"
        shift 2
        ;;
      --source)
        source="$2"
        shift 2
        ;;
      --author)
        author="$2"
        shift 2
        ;;
      --trust)
        trust="$2"
        shift 2
        ;;
      *)
        echo "Unknown option: $1"
        exit 1
        ;;
    esac
  done

  # Generate next signal ID
  local next_id=1
  if [[ -f "$SIGNALS_DIR"/*.md ]]; then
    local last_id=$(grep -h "^id: SIG-" "$SIGNALS_DIR"/*.md 2>/dev/null | sed 's/^id: SIG-//' | sort -n | tail -1)
    next_id=$((last_id + 1))
  fi
  local sig_id=$(printf "SIG-%03d" $next_id)

  # Generate filename from title
  local filename=$(echo "$title" | tr '[:upper:]' '[:lower:]' | sed 's/[^a-z0-9]/-/g' | sed 's/-\+/-/g' | sed 's/^-\|-$//g')
  local timestamp=$(date -u +"%Y-%m-%dT%H:%M:%SZ")
  local signal_file="$SIGNALS_DIR/${timestamp:0:10}-${filename}.md"

  # Build frontmatter
  cat > "$signal_file" <<EOF
---
id: $sig_id
timestamp: $timestamp
source: $source
EOF

  if [[ -n "$author" ]]; then
    echo "author: $author" >> "$signal_file"
  fi

  cat >> "$signal_file" <<EOF
confidence: $confidence
EOF

  if [[ -n "$trust" ]]; then
    echo "trust: $trust" >> "$signal_file"
  fi

  cat >> "$signal_file" <<EOF
status: captured
cluster:
autonomy_level:
parent_signal:
related_intents: []
---
# Signal: $title

EOF

  if [[ -n "$body" ]]; then
    echo "$body" >> "$signal_file"
  fi

  echo "Captured: $sig_id at $signal_file"
}

# --- Subcommand: review ---
review_signal() {
  local target="${1:-}"
  if [[ -z "$target" ]]; then
    echo "Interactive review mode: not yet implemented."
    echo "Use: intent-signal review SIG-001 to review a specific signal."
    return
  fi

  # Find and display signal
  local signal_file=$(grep -l "^id: $target" "$SIGNALS_DIR"/*.md 2>/dev/null | head -1)
  if [[ -z "$signal_file" ]]; then
    echo "Signal $target not found."
    exit 1
  fi

  echo "=== $target ==="
  cat "$signal_file"
}

# --- Subcommand: dismiss ---
dismiss_signal() {
  local sig_id="$1"
  local reason="${2:-No reason provided}"
  shift 2 || true

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --reason)
        reason="$2"
        shift 2
        ;;
      *)
        echo "Unknown option: $1"
        exit 1
        ;;
    esac
  done

  local signal_file=$(grep -l "^id: $sig_id" "$SIGNALS_DIR"/*.md 2>/dev/null | head -1)
  if [[ -z "$signal_file" ]]; then
    echo "Signal $sig_id not found."
    exit 1
  fi

  # Update status to dismissed
  sed -i "s/^status: .*/status: dismissed/" "$signal_file"
  echo "Dismissed: $sig_id (reason: $reason)"
}

# --- Subcommand: cluster ---
cluster_signal() {
  local sig_ids="$1"
  local cluster_name="${2:-}"
  shift 2 || true

  while [[ $# -gt 0 ]]; do
    case "$1" in
      --name)
        cluster_name="$2"
        shift 2
        ;;
      *)
        echo "Unknown option: $1"
        exit 1
        ;;
    esac
  done

  if [[ -z "$cluster_name" ]]; then
    echo "Error: --name is required for clustering."
    exit 1
  fi

  # Split comma-separated IDs and update each
  IFS=',' read -ra ids <<< "$sig_ids"
  for id in "${ids[@]}"; do
    local signal_file=$(grep -l "^id: $id" "$SIGNALS_DIR"/*.md 2>/dev/null | head -1)
    if [[ -n "$signal_file" ]]; then
      sed -i "s/^cluster: .*/cluster: $cluster_name/" "$signal_file"
      echo "Clustered: $id -> $cluster_name"
    else
      echo "Signal $id not found."
    fi
  done
}

# --- Subcommand: promote ---
promote_signal() {
  local sig_id="$1"

  local signal_file=$(grep -l "^id: $sig_id" "$SIGNALS_DIR"/*.md 2>/dev/null | head -1)
  if [[ -z "$signal_file" ]]; then
    echo "Signal $sig_id not found."
    exit 1
  fi

  # Update status to promoted
  sed -i "s/^status: .*/status: promoted/" "$signal_file"
  echo "Promoted: $sig_id to intent (manual workflow follows)"
}

# --- Subcommand: list ---
list_signals() {
  local status="active"
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --status)
        status="$2"
        shift 2
        ;;
      *)
        echo "Unknown option: $1"
        exit 1
        ;;
    esac
  done

  echo "Signals (status: $status):"
  if [[ "$status" == "all" ]]; then
    grep -h "^id: SIG-" "$SIGNALS_DIR"/*.md 2>/dev/null | sort
  else
    for file in "$SIGNALS_DIR"/*.md; do
      if [[ -f "$file" ]] && grep -q "^status: $status" "$file"; then
        grep "^id: SIG-" "$file"
      fi
    done | sort
  fi
}

# --- Subcommand: show ---
show_signal() {
  local sig_id="$1"
  local signal_file=$(grep -l "^id: $sig_id" "$SIGNALS_DIR"/*.md 2>/dev/null | head -1)

  if [[ -z "$signal_file" ]]; then
    echo "Signal $sig_id not found."
    exit 1
  fi

  echo "=== $sig_id ==="
  cat "$signal_file"
  echo ""
  echo "File: $signal_file"
}

# --- Main dispatch ---
if [[ $# -eq 0 ]]; then
  echo "intent-signal: No command provided. Use 'intent-signal review' or 'intent-signal "Title"'"
  exit 1
fi

command="$1"
shift

case "$command" in
  review)
    review_signal "$@"
    ;;
  dismiss)
    dismiss_signal "$@"
    ;;
  cluster)
    cluster_signal "$@"
    ;;
  promote)
    promote_signal "$@"
    ;;
  list)
    list_signals "$@"
    ;;
  show)
    show_signal "$@"
    ;;
  *)
    # Default: capture a new signal with the command as title
    capture_signal "$command" "$@"
    ;;
esac

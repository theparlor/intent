#!/bin/bash
#
# intent-signal — Capture and manage signals
#
# Usage:
#   intent-signal "OTel traces show 40% of contracts fail on first pass"
#   intent-signal "Title here" --body "Longer description" --confidence 0.8
#   intent-signal "Title here" --source pr-review --author brien --trust 0.6
#   intent-signal review                    # Interactive triage of captured signals
#   intent-signal review SIG-003            # Review a specific signal
#   intent-signal dismiss SIG-003 --reason "Duplicate of SIG-001"
#   intent-signal cluster SIG-003,SIG-005 --name "Bootstrap tooling"
#   intent-signal promote SIG-003           # Promote signal to intent
#   intent-signal list                      # List all signals (default: active)
#   intent-signal list --status captured    # Filter by status
#   intent-signal show SIG-003              # Show full signal details
#
# Writes to .intent/signals/ in the nearest Intent-native repo.

set -euo pipefail

# --- Find .intent/ directory ---
find_intent_root() {
  local dir="$PWD"
  while [[ "$dir" != "/" ]]; do
    if [[ -d "$dir/.intent" ]]; then
      echo "$dir"
      return 0
    fi
    dir="$(dirname "$dir")"
  done
  return 1
}

REPO_ROOT=$(find_intent_root) || {
  echo "Error: No .intent/ directory found. Are you in an Intent-native repo?" >&2
  echo "Run: mkdir -p .intent/signals .intent/events" >&2
  exit 1
}

SIGNALS_DIR="$REPO_ROOT/.intent/signals"
EVENTS_DIR="$REPO_ROOT/.intent/events"
INTENTS_DIR="$REPO_ROOT/.intent/intents"
mkdir -p "$SIGNALS_DIR" "$EVENTS_DIR" "$INTENTS_DIR"

EVENTS_FILE="$EVENTS_DIR/events.jsonl"
TIMESTAMP=$(date -u +"%Y-%m-%dT%H:%M:%SZ")

# --- Helpers ---
emit_event() {
  local event_type="$1"
  local signal_id="$2"
  local data="$3"
  local event="{\"version\":\"0.1.0\",\"event\":\"${event_type}\",\"timestamp\":\"${TIMESTAMP}\",\"trace_id\":null,\"span_id\":\"${signal_id}\",\"parent_id\":null,\"source\":\"cli\",\"data\":${data}}"
  echo "$event" >> "$EVENTS_FILE"
}

get_field() {
  local file="$1"
  local field="$2"
  grep -oP "^${field}:\\s*\\K.*" "$file" 2>/dev/null | head -1 | sed 's/^[ \t]*//' || true
}

get_title() {
  local file="$1"
  grep -m1 '^# ' "$file" 2>/dev/null | sed 's/^# //' || echo "(untitled)"
}

find_signal_file() {
  local sig_id="$1"
  for f in "$SIGNALS_DIR"/*.md; do
    [[ -f "$f" ]] || continue
    if grep -q "^id: ${sig_id}$" "$f" 2>/dev/null; then
      echo "$f"
      return 0
    fi
  done
  echo "Error: Signal $sig_id not found" >&2
  return 1
}

next_signal_id() {
  local next=1
  for f in "$SIGNALS_DIR"/*.md 2>/dev/null; do
    [[ -f "$f" ]] || continue
    local id_num
    id_num=$(grep -oP 'id:\s*SIG-\K\d+' "$f" 2>/dev/null || true)
    if [[ -n "$id_num" ]] && (( id_num >= next )); then
      next=$((id_num + 1))
    fi
  done
  printf "SIG-%03d" "$next"
}

set_field() {
  local file="$1"
  local field="$2"
  local value="$3"
  if grep -q "^${field}:" "$file" 2>/dev/null; then
    # Field exists — replace it
    if [[ "$(uname)" == "Darwin" ]]; then
      sed -i '' "s|^${field}:.*|${field}: ${value}|" "$file"
    else
      sed -i "s|^${field}:.*|${field}: ${value}|" "$file"
    fi
  else
    # Field doesn't exist — insert before closing ---
    if [[ "$(uname)" == "Darwin" ]]; then
      sed -i '' "/^---$/a\\
${field}: ${value}" "$file"
    else
      sed -i "0,/^---$/!{0,/^---$/s/^---$/${field}: ${value}\n---/}" "$file"
    fi
  fi
}

compute_autonomy_level() {
  local trust="$1"
  if [[ -z "$trust" || "$trust" == "null" ]]; then
    echo ""
    return
  fi
  # Use awk for floating point comparison
  echo "$trust" | awk '{
    if ($1 < 0.2) print "L0"
    else if ($1 < 0.4) print "L1"
    else if ($1 < 0.6) print "L2"
    else if ($1 < 0.85) print "L3"
    else print "L4"
  }'
}

# --- Subcommand dispatch ---
SUBCMD=""
case "${1:-}" in
  review|dismiss|cluster|promote|list|show|help|--help|-h)
    SUBCMD="$1"
    shift
    ;;
esac

# ==============================
# CAPTURE (default — no subcommand)
# ==============================
cmd_capture() {
  local TITLE="" BODY="" CONFIDENCE="" TRUST="" SOURCE="cli" AUTHOR="${USER:-unknown}" COMMIT=false

  while [[ $# -gt 0 ]]; do
    case $1 in
      --body) BODY="$2"; shift 2 ;;
      --confidence) CONFIDENCE="$2"; shift 2 ;;
      --trust) TRUST="$2"; shift 2 ;;
      --source) SOURCE="$2"; shift 2 ;;
      --author) AUTHOR="$2"; shift 2 ;;
      --commit) COMMIT=true; shift ;;
      --help|-h)
        echo "Usage: intent-signal \"Title\" [--body TEXT] [--confidence 0.0-1.0] [--trust 0.0-1.0] [--source NAME] [--author NAME] [--commit]"
        echo ""
        echo "Captures a signal in .intent/signals/ of the nearest Intent-native repo."
        exit 0
        ;;
      *)
        if [[ -z "$TITLE" ]]; then
          TITLE="$1"
        else
          echo "Error: Unexpected argument '$1'. Did you forget --body?" >&2
          exit 1
        fi
        shift
        ;;
    esac
  done

  if [[ -z "$TITLE" ]]; then
    echo "Error: Signal title required." >&2
    echo "Usage: intent-signal \"What you noticed\"" >&2
    exit 1
  fi

  local DATE
  DATE=$(date -u +"%Y-%m-%d")
  local SLUG
  SLUG=$(echo "$TITLE" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alnum:]' '-' | head -c 60 | sed 's/-$//')
  local SIGNAL_ID
  SIGNAL_ID=$(next_signal_id)
  local FILENAME="${DATE}-${SLUG}.md"
  local FILEPATH="$SIGNALS_DIR/$FILENAME"

  local AUTONOMY=""
  if [[ -n "$TRUST" ]]; then
    AUTONOMY=$(compute_autonomy_level "$TRUST")
  fi

  {
    echo "---"
    echo "id: $SIGNAL_ID"
    echo "timestamp: $TIMESTAMP"
    echo "source: $SOURCE"
    echo "author: $AUTHOR"
    [[ -n "$CONFIDENCE" ]] && echo "confidence: $CONFIDENCE"
    [[ -n "$TRUST" ]] && echo "trust: $TRUST"
    [[ -n "$AUTONOMY" ]] && echo "autonomy_level: $AUTONOMY"
    echo "status: captured"
    echo "cluster:"
    echo "parent_signal:"
    echo "related_intents: []"
    echo "---"
    echo "# $TITLE"
    if [[ -n "$BODY" ]]; then
      echo ""
      echo "$BODY"
    fi
  } > "$FILEPATH"

  emit_event "signal.created" "$SIGNAL_ID" "{\"signal_id\":\"$SIGNAL_ID\",\"title\":\"$TITLE\",\"confidence\":${CONFIDENCE:-null},\"trust\":${TRUST:-null},\"autonomy_level\":\"${AUTONOMY:-unscored}\",\"author\":\"$AUTHOR\",\"file\":\".intent/signals/$FILENAME\"}"

  local REL_PATH=".intent/signals/$FILENAME"
  echo "Signal captured: $SIGNAL_ID"
  echo "File: $REL_PATH"
  [[ -n "$TRUST" ]] && echo "Trust: $TRUST → $AUTONOMY"
  echo "Event: signal.created → .intent/events/events.jsonl"

  if $COMMIT; then
    cd "$REPO_ROOT"
    git add "$REL_PATH" ".intent/events/events.jsonl"
    git commit -m "signal: ${TITLE:0:50}"
    echo "Committed."
  else
    echo ""
    echo "To commit:"
    echo "  git add $REL_PATH .intent/events/events.jsonl"
    echo "  git commit -m 'signal: ${TITLE:0:50}'"
  fi
}

# ==============================
# LIST
# ==============================
cmd_list() {
  local FILTER_STATUS="" SHOW_ALL=false

  while [[ $# -gt 0 ]]; do
    case $1 in
      --status) FILTER_STATUS="$2"; shift 2 ;;
      --all) SHOW_ALL=true; shift ;;
      *) echo "Error: Unknown option '$1'" >&2; exit 1 ;;
    esac
  done

  printf "%-8s  %-10s  %-5s  %-5s  %-4s  %s\n" "ID" "STATUS" "CONF" "TRUST" "LVL" "TITLE"
  printf "%-8s  %-10s  %-5s  %-5s  %-4s  %s\n" "------" "--------" "----" "-----" "---" "-----"

  for f in "$SIGNALS_DIR"/*.md; do
    [[ -f "$f" ]] || continue
    local id status conf trust autonomy title
    id=$(get_field "$f" "id")
    status=$(get_field "$f" "status")
    conf=$(get_field "$f" "confidence")
    trust=$(get_field "$f" "trust")
    autonomy=$(get_field "$f" "autonomy_level")
    title=$(get_title "$f")

    # Default status for signals without one
    [[ -z "$status" ]] && status="captured"

    # Apply filter
    if [[ -n "$FILTER_STATUS" && "$status" != "$FILTER_STATUS" ]]; then
      continue
    fi
    # By default, hide dismissed unless --all or --status dismissed
    if [[ "$SHOW_ALL" == "false" && -z "$FILTER_STATUS" && "$status" == "dismissed" ]]; then
      continue
    fi

    printf "%-8s  %-10s  %-5s  %-5s  %-4s  %s\n" \
      "${id:-?}" "${status:-?}" "${conf:--}" "${trust:--}" "${autonomy:--}" "${title:0:60}"
  done
}

# ==============================
# SHOW
# ==============================
cmd_show() {
  local sig_id="$1"
  if [[ -z "$sig_id" ]]; then
    echo "Usage: intent-signal show SIG-XXX" >&2
    exit 1
  fi
  local file
  file=$(find_signal_file "$sig_id") || exit 1
  cat "$file"
}

# ==============================
# REVIEW — triage captured signals
# ==============================
cmd_review() {
  local sig_id="${1:-}"

  if [[ -n "$sig_id" ]]; then
    # Review a specific signal
    local file
    file=$(find_signal_file "$sig_id") || exit 1
    local title status conf trust autonomy cluster
    title=$(get_title "$file")
    status=$(get_field "$file" "status")
    conf=$(get_field "$file" "confidence")
    trust=$(get_field "$file" "trust")
    autonomy=$(get_field "$file" "autonomy_level")
    cluster=$(get_field "$file" "cluster")

    echo "┌─────────────────────────────────────────────────────────────┐"
    echo "│  $sig_id — REVIEW"
    echo "├─────────────────────────────────────────────────────────────┤"
    echo "│  Title:     $title"
    echo "│  Status:    ${status:-captured}"
    echo "│  Confidence:${conf:- unscored}"
    echo "│  Trust:     ${trust:- unscored}"
    echo "│  Autonomy:  ${autonomy:- unclassified}"
    echo "│  Cluster:   ${cluster:- none}"
    echo "├─────────────────────────────────────────────────────────────┤"
    echo "│  Actions:"
    echo "│    intent-signal dismiss $sig_id --reason \"...\""
    echo "│    intent-signal cluster $sig_id,SIG-XXX --name \"...\""
    echo "│    intent-signal promote $sig_id"
    echo "└─────────────────────────────────────────────────────────────┘"
    return
  fi

  # Review all captured/active signals
  echo "═══ Signal Triage ═══"
  echo ""

  local count=0
  for f in "$SIGNALS_DIR"/*.md; do
    [[ -f "$f" ]] || continue
    local id status conf trust autonomy title
    id=$(get_field "$f" "id")
    status=$(get_field "$f" "status")
    [[ -z "$status" ]] && status="captured"

    # Only show captured and active signals for review
    [[ "$status" != "captured" && "$status" != "active" ]] && continue

    conf=$(get_field "$f" "confidence")
    trust=$(get_field "$f" "trust")
    autonomy=$(get_field "$f" "autonomy_level")
    title=$(get_title "$f")

    local trust_bar=""
    if [[ -n "$trust" && "$trust" != "null" ]]; then
      local pct
      pct=$(echo "$trust" | awk '{printf "%d", $1 * 10}')
      trust_bar=$(printf '█%.0s' $(seq 1 "$pct" 2>/dev/null) || true)
      trust_bar=$(printf "%-10s" "$trust_bar")
    else
      trust_bar="unscored  "
    fi

    printf "  %s  %-10s  [%s]  %s  %s\n" "$id" "$status" "$trust_bar" "${autonomy:--}" "$title"
    count=$((count + 1))
  done

  echo ""
  if [[ $count -eq 0 ]]; then
    echo "  No signals awaiting triage."
  else
    echo "  $count signal(s) awaiting triage."
    echo ""
    echo "  Actions:"
    echo "    intent-signal review SIG-XXX              # Review details"
    echo "    intent-signal dismiss SIG-XXX --reason \"\" # Dismiss"
    echo "    intent-signal promote SIG-XXX             # Promote to intent"
    echo "    intent-signal cluster SIG-X,SIG-Y --name \"\" # Group"
  fi
}

# ==============================
# DISMISS
# ==============================
cmd_dismiss() {
  local sig_id="$1"
  shift || true
  local REASON=""

  while [[ $# -gt 0 ]]; do
    case $1 in
      --reason) REASON="$2"; shift 2 ;;
      *) echo "Error: Unknown option '$1'" >&2; exit 1 ;;
    esac
  done

  if [[ -z "$sig_id" ]]; then
    echo "Usage: intent-signal dismiss SIG-XXX [--reason TEXT]" >&2
    exit 1
  fi

  local file
  file=$(find_signal_file "$sig_id") || exit 1

  set_field "$file" "status" "dismissed"
  local title
  title=$(get_title "$file")

  emit_event "signal.dismissed" "$sig_id" "{\"signal_id\":\"$sig_id\",\"reason\":\"${REASON}\",\"title\":\"$title\"}"

  echo "Dismissed: $sig_id — $title"
  [[ -n "$REASON" ]] && echo "Reason: $REASON"
  echo "Event: signal.dismissed → .intent/events/events.jsonl"
}

# ==============================
# CLUSTER
# ==============================
cmd_cluster() {
  local sig_ids_raw="$1"
  shift || true
  local CLUSTER_NAME=""

  while [[ $# -gt 0 ]]; do
    case $1 in
      --name) CLUSTER_NAME="$2"; shift 2 ;;
      *) echo "Error: Unknown option '$1'" >&2; exit 1 ;;
    esac
  done

  if [[ -z "$sig_ids_raw" ]]; then
    echo "Usage: intent-signal cluster SIG-001,SIG-003 --name \"Cluster name\"" >&2
    exit 1
  fi

  if [[ -z "$CLUSTER_NAME" ]]; then
    echo "Error: --name required for clustering" >&2
    exit 1
  fi

  # Slugify cluster name
  local cluster_slug
  cluster_slug=$(echo "$CLUSTER_NAME" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alnum:]' '-' | head -c 40 | sed 's/-$//')

  IFS=',' read -ra SIG_IDS <<< "$sig_ids_raw"
  local clustered=()

  for sig_id in "${SIG_IDS[@]}"; do
    sig_id=$(echo "$sig_id" | tr -d ' ')
    local file
    file=$(find_signal_file "$sig_id") || continue
    set_field "$file" "status" "clustered"
    set_field "$file" "cluster" "$cluster_slug"
    clustered+=("$sig_id")
  done

  emit_event "signal.clustered" "${clustered[0]}" "{\"cluster\":\"$cluster_slug\",\"signals\":[$(printf '\"%s\",' "${clustered[@]}" | sed 's/,$//')]}"

  echo "Clustered ${#clustered[@]} signals as: $CLUSTER_NAME"
  for sid in "${clustered[@]}"; do
    echo "  $sid → cluster: $cluster_slug"
  done
  echo "Event: signal.clustered → .intent/events/events.jsonl"
}

# ==============================
# PROMOTE — promote signal to intent
# ==============================
cmd_promote() {
  local sig_id="$1"
  shift || true
  local COMMIT=false

  while [[ $# -gt 0 ]]; do
    case $1 in
      --commit) COMMIT=true; shift ;;
      *) echo "Error: Unknown option '$1'" >&2; exit 1 ;;
    esac
  done

  if [[ -z "$sig_id" ]]; then
    echo "Usage: intent-signal promote SIG-XXX [--commit]" >&2
    exit 1
  fi

  local file
  file=$(find_signal_file "$sig_id") || exit 1

  local title
  title=$(get_title "$file")
  local confidence
  confidence=$(get_field "$file" "confidence")

  # Update signal status
  set_field "$file" "status" "promoted"

  # Generate next intent ID
  local next_int=1
  for f in "$INTENTS_DIR"/*.md 2>/dev/null; do
    [[ -f "$f" ]] || continue
    local id_num
    id_num=$(grep -oP 'id:\s*INT-\K\d+' "$f" 2>/dev/null || true)
    if [[ -n "$id_num" ]] && (( id_num >= next_int )); then
      next_int=$((id_num + 1))
    fi
  done
  local INTENT_ID
  INTENT_ID=$(printf "INT-%03d" "$next_int")

  local DATE
  DATE=$(date -u +"%Y-%m-%d")
  local SLUG
  SLUG=$(echo "$title" | tr '[:upper:]' '[:lower:]' | tr -cs '[:alnum:]' '-' | head -c 60 | sed 's/-$//')
  local INTENT_FILE="$INTENTS_DIR/${DATE}-${SLUG}.md"

  # Create intent from signal
  {
    echo "---"
    echo "id: $INTENT_ID"
    echo "timestamp: $TIMESTAMP"
    echo "status: proposed"
    echo "priority: next"
    echo "product:"
    echo "author: ${USER:-unknown}"
    echo "source_signals: [$sig_id]"
    echo "outcome:"
    echo "---"
    echo "# $title"
    echo ""
    echo "Promoted from $sig_id."
    echo ""
    echo "## Hypothesis"
    echo ""
    echo "<!-- What change do you believe will produce the desired outcome? -->"
    echo ""
    echo "## Outcome"
    echo ""
    echo "<!-- What measurable result would validate this intent? -->"
  } > "$INTENT_FILE"

  emit_event "signal.promoted" "$sig_id" "{\"signal_id\":\"$sig_id\",\"intent_id\":\"$INTENT_ID\",\"title\":\"$title\"}"
  emit_event "intent.proposed" "$INTENT_ID" "{\"intent_id\":\"$INTENT_ID\",\"source_signal\":\"$sig_id\",\"title\":\"$title\"}"

  echo "Promoted: $sig_id → $INTENT_ID"
  echo "Signal:   $sig_id status → promoted"
  echo "Intent:   .intent/intents/${DATE}-${SLUG}.md"
  echo "Events:   signal.promoted, intent.proposed → events.jsonl"

  if $COMMIT; then
    cd "$REPO_ROOT"
    local sig_rel
    sig_rel=$(echo "$file" | sed "s|${REPO_ROOT}/||")
    local int_rel=".intent/intents/${DATE}-${SLUG}.md"
    git add "$sig_rel" "$int_rel" ".intent/events/events.jsonl"
    git commit -m "promote: $sig_id → $INTENT_ID — $title"
    echo "Committed."
  fi
}

# ==============================
# HELP
# ==============================
cmd_help() {
  cat <<'HELP'
intent-signal — Capture and manage signals in the Intent system

CAPTURE:
  intent-signal "Title"                          Capture a new signal
  intent-signal "Title" --confidence 0.8         With confidence score
  intent-signal "Title" --trust 0.7              With trust score (auto-computes autonomy level)
  intent-signal "Title" --source pr-review       With source attribution
  intent-signal "Title" --commit                 Auto-commit after capture

TRIAGE:
  intent-signal review                           Show all signals awaiting triage
  intent-signal review SIG-003                   Review a specific signal

LIFECYCLE:
  intent-signal dismiss SIG-003 --reason "..."   Dismiss a signal
  intent-signal cluster SIG-001,SIG-003 --name "Group name"
                                                 Group related signals
  intent-signal promote SIG-003                  Promote signal → intent
  intent-signal promote SIG-003 --commit         Promote and auto-commit

QUERY:
  intent-signal list                             List active signals
  intent-signal list --status captured           Filter by status
  intent-signal list --all                       Include dismissed
  intent-signal show SIG-003                     Show full signal file

STATUS VALUES:
  captured    Newly captured, awaiting triage
  active      Under investigation / being enriched
  clustered   Grouped with related signals
  promoted    Promoted to an intent
  dismissed   Dismissed (hidden from default list)

TRUST & AUTONOMY:
  Trust score (0.0-1.0) determines autonomy level:
    L0 (<0.2)     Human drives
    L1 (0.2-0.4)  Agent assists
    L2 (0.4-0.6)  Agent decides, human approves
    L3 (0.6-0.85) Agent executes, human monitors
    L4 (≥0.85)    Full autonomy, circuit breakers only
HELP
}

# ==============================
# MAIN DISPATCH
# ==============================
case "$SUBCMD" in
  "") cmd_capture "$@" ;;
  list) cmd_list "$@" ;;
  show) cmd_show "$@" ;;
  review) cmd_review "$@" ;;
  dismiss) cmd_dismiss "$@" ;;
  cluster) cmd_cluster "$@" ;;
  promote) cmd_promote "$@" ;;
  help|--help|-h) cmd_help ;;
  *) echo "Unknown command: $SUBCMD" >&2; cmd_help; exit 1 ;;
esac
